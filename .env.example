DATABASE_URL="postgresql://postgres:postgres@localhost:5432/opengrowth"
# Agent runtime. PostgreSQL only — Prisma cannot use enums on SQLite, and the
# datasource provider cannot be set from env(). Start a local server with:
# docker run --name opengrowth-pg -e POSTGRES_PASSWORD=postgres \
#   -e POSTGRES_DB=opengrowth -p 5432:5432 -d postgres:16
AGENT_TICK_SECRET=""
AGENT_TICK_MAX_CLIENTS="5"
AGENT_TICK_LEASE_MS="120000"
# Integration tests are opt-in; a DATABASE_URL alone does not mean a live server.
RUN_DB_TESTS=""
AI_PROVIDER="mock"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-flash-latest"
ANALYTICS_PROVIDER="mock"
OPENGROWTH_AUDIT_STORE="file"
OPENGROWTH_REAL_CRAWL="false"
OPENGROWTH_AUDIT_STORE_PATH=".opengrowth/audit-runs.json"
CRAWLER_TIMEOUT_MS="8000"
CRAWLER_MAX_BYTES="2000000"
# Search demand providers (SEARCH-001). auto → GSC if set, else keyword URL, else demo.
OPENGROWTH_SEARCH_PROVIDER="auto"
GSC_SITE_URL=""
GSC_ACCESS_TOKEN=""
KEYWORD_PROVIDER_URL=""
KEYWORD_PROVIDER_API_KEY=""
# Epic 3 — bandit + SDR
OPENGROWTH_BANDIT_STORE="file"
OPENGROWTH_OBJECT_STORE="file"
OPENGROWTH_PDF="html"
GOOGLE_PLACES_API_KEY=""
REDIS_URL=""
