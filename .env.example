DATABASE_URL="postgresql://postgres:postgres@localhost:5432/opengrowth"
# Agent runtime. PostgreSQL only — Prisma cannot use enums on SQLite, and the
# datasource provider cannot be set from env(). Start a local server with:
# docker run --name opengrowth-pg -e POSTGRES_PASSWORD=postgres \
#   -e POSTGRES_DB=opengrowth -p 5432:5432 -d postgres:16
AGENT_TICK_SECRET=""
AGENT_TICK_MAX_CLIENTS="5"
AGENT_TICK_LEASE_MS="120000"
# Integration tests are opt-in; a DATABASE_URL alone does not mean a live server.
RUN_DB_TESTS=""
AI_PROVIDER="mock"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-flash-latest"
ANALYTICS_PROVIDER="mock"
OPENGROWTH_AUDIT_STORE="file"
OPENGROWTH_REAL_CRAWL="false"
OPENGROWTH_AUDIT_STORE_PATH=".opengrowth/audit-runs.json"
CRAWLER_TIMEOUT_MS="8000"
CRAWLER_MAX_BYTES="2000000"
# Search demand providers (SEARCH-001). auto → GSC if set, else keyword URL, else demo.
OPENGROWTH_SEARCH_PROVIDER="auto"
GSC_SITE_URL=""
GSC_ACCESS_TOKEN=""
KEYWORD_PROVIDER_URL=""
KEYWORD_PROVIDER_API_KEY=""
# Epic 3 — bandit + SDR
OPENGROWTH_BANDIT_STORE="file"
OPENGROWTH_OBJECT_STORE="file"
OPENGROWTH_PDF="html"
GOOGLE_PLACES_API_KEY=""
REDIS_URL=""

# ── Open-Source Ingestion (OSI) ─────────────────────────────────────────────
# Multi-page crawl engine. mock (default) | http (dependency-free BFS) | crawlee
OPENGROWTH_SITE_CRAWLER="mock"
# Clean extraction. cheerio (default) | firecrawl
OPENGROWTH_EXTRACTOR="cheerio"
FIRECRAWL_URL=""
FIRECRAWL_API_KEY=""
# Embeddings for the vector index. mock (default) | local | openai
OPENGROWTH_EMBEDDINGS="mock"
# Retrieval backbone. memory (default) | opensearch
OPENGROWTH_EVIDENCE_INDEX="memory"
OPENSEARCH_URL="http://localhost:9200"
OPENSEARCH_INDEX="opengrowth-evidence"

# ── Marketing Data Mesh (MDM) ───────────────────────────────────────────────
# Real GEO citation measurement. mock (default) | perplexity | openai
OPENGROWTH_ANSWER_ENGINE="mock"
PERPLEXITY_API_KEY=""
# SERP + citation verification. mock (default) | searxng
OPENGROWTH_SERP="mock"
SEARXNG_URL="http://localhost:8080"
# Core Web Vitals / performance. mock (default) | psi | lighthouse
OPENGROWTH_PERF="mock"
PSI_API_KEY=""
# Backlinks / authority. mock (default) | open-pagerank | common-crawl
OPENGROWTH_BACKLINKS="mock"
OPEN_PAGERANK_API_KEY=""
COMMON_CRAWL_INDEX_URL="https://index.commoncrawl.org/CC-MAIN-2024-10-index"
